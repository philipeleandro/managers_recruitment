<div class="flex flex-col items-center justify-center min-h-[calc(100vh-10rem)] w-full px-4">
  <div class="w-full mx-auto max-w-md">
    <div class="rounded-xl border border-slate-200 bg-white p-6">
      <h2 class="text-lg font-semibold text-slate-900 mb-6"><%= t('devise.registrations.edit.title') %></h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="grid grid-cols-1 gap-6">
          <div class="col-span-1">
            <%= f.label :email, class: "block text-sm text-slate-900 mb-2" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full py-2.5 pl-4 text-sm rounded-lg border border-slate-300 px-4 py-2 text-slate-900 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
          </div>

          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="col-span-1">
              <span><%= t('devise.registrations.edit.waiting_confirmation_for_email', email: resource.unconfirmed_email) %></span>
            </div>
          <% end %>

          <div class="col-span-1">
            <%= f.label :password, class: "block text-sm text-slate-900 mb-2" %> <i>(<%= t('devise.registrations.edit.leave_blank_if_you_don_t_want_to_change_it') %>)</i><br />
            <%= f.password_field :password, autocomplete: "new-password", class: "w-full py-2.5 pl-4 text-sm rounded-lg border border-slate-300 px-4 py-2 text-slate-900 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
            <% if @minimum_password_length %>
              <br />
              <em><%= t('devise.registrations.edit.password_length', count: @minimum_password_length) %></em>
            <% end %>
          </div>

          <div class="col-span-1">
            <%= f.label :password_confirmation, class: "block text-sm text-slate-900 mb-2" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full py-2.5 pl-4 text-sm rounded-lg border border-slate-300 px-4 py-2 text-slate-900 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
          </div>

          <div class="col-span-1">
            <%= f.label :current_password, class: "block text-sm text-slate-900 mb-2" %> <i>(<%= t('devise.registrations.edit.we_need_your_current_password_to_confirm_your_changes') %>)</i><br />
            <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full py-2.5 pl-4 text-sm rounded-lg border border-slate-300 px-4 py-2 text-slate-900 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
          </div>
        </div>

        <div class="mt-8 flex gap-6">
          <%= f.submit t('devise.registrations.edit.update'), class: "rounded-lg w-full bg-blue-600 px-6 py-2 text-sm font-medium text-white hover:bg-blue-700 cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-6 text-center">
        <p class="text-sm text-slate-600"><%= t('devise.registrations.edit.unhappy?') %> <%= button_to t('devise.registrations.edit.cancel_my_account'), registration_path(resource_name), data: { confirm: t('devise.registrations.edit.are_you_sure') }, method: :delete, class: "font-medium text-blue-600 hover:underline" %></p>
        <%= link_to t('devise.shared.links.back'), :back, class: "text-sm font-medium text-slate-600 hover:underline" %>
      </div>
    </div>
  </div>
</div>
