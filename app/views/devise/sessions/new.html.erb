<div class="min-h-screen bg-gradient-to-br flex items-center justify-center px-4">
  <div class="w-full max-w-md -translate-y-14">
    <div class="bg-white flex flex-col gap-6 rounded-xl py-6 shadow-lg border-0">
      <div class="px-6 pb-4">
        <div class="font-semibold text-2xl text-slate-900"><%= t('devise.sessions.new.welcome') %></div>
        <div class="text-slate-500 text-sm"><%= t('devise.sessions.new.prompt') %></div>
      </div>

      <div class="px-6">
        <%= form_with(model: resource, as: resource_name, url: session_path(resource_name), local: true, class: "space-y-5") do |form| %>
          <div>
            <%= form.label :email, t('devise.sessions.form.label.email'), class: "block text-sm font-medium text-slate-900 mb-2" %>
            <%= form.email_field :email,
                autofocus: true,
                autocomplete: "email",
                placeholder: t('devise.sessions.form.placeholder.email'),
                class: "w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-slate-900 placeholder-slate-400 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-colors" %>
          </div>

          <div>
            <%= form.label :password, t('devise.sessions.form.label.password'), class: "block text-sm font-medium text-slate-900 mb-2" %>
            <div class="relative">
              <%= form.password_field :password,
                  placeholder: "••••••••",
                  class: "w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-slate-900 placeholder-slate-400 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-colors" %>
              <%# <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye h-4 w-4"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
              </button> %>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <% if devise_mapping.rememberable? %>
              <label class="flex items-center gap-2 cursor-pointer">
                <%= form.check_box :remember_me, class: "rounded border-slate-200 text-blue-600 focus:ring-blue-500 cursor-pointer" %>
                <span class="text-sm text-slate-600"><%= t('devise.sessions.new.remember_me') %></span>
              </label>
            <% end %>

            <% if devise_mapping.recoverable? %>
              <%= link_to t('devise.shared.links.forgot_your_password'), new_password_path(resource_name), class: "text-sm font-medium text-blue-600 hover:text-blue-700" %>
            <% end %>
          </div>

          <%= form.submit t('devise.sessions.new.sign_in'), class: "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md transition-all bg-blue-600 text-white hover:bg-blue-700 h-9 px-4 w-full text-base font-medium cursor-pointer shadow-sm" %>

          <div class="text-center">
            <span class="text-sm text-slate-600">
              <%= t('devise.sessions.new.no_account') %>
              <%= link_to t('devise.shared.links.sign_up'), new_registration_path(resource_name), class: "font-medium text-blue-600 hover:text-blue-700" %>
            </span>
          </div>

        <% end %>
      </div>
    </div>
  </div>
</div>
