<p class="text-base text-slate-700 mb-4">
  <%= t('devise.mailer.reset_password_instructions.hello', email: @email) %>
</p>

<p class="text-base text-slate-700 mb-6">
  <%= t('devise.mailer.reset_password_instructions.someone_has_requested_a_link_to_change_your_password_you_can_do_this_through_the_link_below') %>
</p>

<p class="text-center mb-6">
  <%= link_to t('devise.mailer.reset_password_instructions.change_my_password'), edit_password_url(@resource, reset_password_token: @token), class: 'btn-mailer' %>
</p>

<p class="text-sm text-slate-500 mb-2">
  <%= t('devise.mailer.reset_password_instructions.if_you_didn_t_request_this_please_ignore_this_email') %>
</p>
<p class="text-sm text-slate-500">
  <%= t('devise.mailer.reset_password_instructions.your_password_won_t_change_until_you_access_the_link_above_and_create_a_new_one') %>
</p>
